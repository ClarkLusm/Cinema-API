# Cinema-API production environment for Vercel
# Replace every placeholder before deploying.

# Frontend domains
FRONTEND_URL=https://your-cinema-frontend.vercel.app
FRONTEND_URLS=https://your-cinema-frontend.vercel.app,https://your-cinema-frontend-git-branch-your-team.vercel.app

# Public backend URL
BACKEND_PUBLIC_URL=https://your-cinema-api.vercel.app

# Authentication
ACTIVATION_SECRET=replace_with_a_long_random_secret_for_jwt_and_activation
ACTIVATION_EXPIRES=1d

# Database
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=your-mysql-database

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password

# OnePay
ONEPAY_PAYMENT_URL=https://mtf.onepay.vn/paygate/vpcpay.op
ONEPAY_MERCHANT=TESTONEPAY
ONEPAY_ACCESS_CODE=6BEB2546
ONEPAY_SECURE_SECRET=6D0870CDE5D40475

# Optional but recommended
TICKET_QR_SECRET=replace_with_a_long_random_secret_for_ticket_qr
